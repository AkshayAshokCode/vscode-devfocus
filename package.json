{
  "name": "devfocus",
  "displayName": "DevFocus",
  "description": "Focus timer and day plan for engineers working with AI — sessions, real breaks, and a defensible end to the day",
  "version": "1.2.1",
  "publisher": "akshayashokcode",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AkshayAshokCode/vscode-devfocus"
  },
  "keywords": [
    "pomodoro",
    "timer",
    "productivity",
    "focus",
    "ai"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devfocus-sidebar",
          "title": "DevFocus",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "devfocus-sidebar": [
        {
          "type": "webview",
          "id": "devfocus.panel",
          "name": "DevFocus"
        }
      ]
    },
    "commands": [
      {
        "command": "devfocus.toggle",
        "title": "DevFocus: Start / Pause Timer",
        "icon": "$(watch)"
      },
      {
        "command": "devfocus.reset",
        "title": "DevFocus: Reset Timer",
        "icon": "$(debug-restart)"
      },
      {
        "command": "devfocus.skipBreak",
        "title": "DevFocus: Skip Break",
        "icon": "$(debug-step-over)"
      },
      {
        "command": "devfocus.openPanel",
        "title": "DevFocus: Open Panel",
        "icon": "$(clock)"
      },
      {
        "command": "devfocus.microBreak",
        "title": "DevFocus: Micro-Break (Waiting on AI)",
        "icon": "$(hubot)"
      },
      {
        "command": "devfocus.captureTask",
        "title": "DevFocus: Add to Later (Capture)",
        "icon": "$(inbox)"
      }
    ],
    "keybindings": [
      {
        "command": "devfocus.toggle",
        "key": "alt+shift+d"
      },
      {
        "command": "devfocus.skipBreak",
        "key": "alt+shift+b"
      },
      {
        "command": "devfocus.microBreak",
        "key": "alt+shift+m"
      },
      {
        "command": "devfocus.captureTask",
        "key": "alt+shift+a"
      }
    ],
    "configuration": {
      "title": "DevFocus",
      "properties": {
        "devfocus.soundEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Play sounds when sessions and breaks end"
        },
        "devfocus.autoStartNextSession": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the next work session after a break"
        },
        "devfocus.notificationsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show desktop notifications when sessions and breaks end"
        },
        "devfocus.defaultMode": {
          "type": "string",
          "enum": [
            "CLASSIC",
            "DEEP_WORK",
            "CUSTOM"
          ],
          "default": "CLASSIC",
          "description": "Default Pomodoro mode on first launch"
        },
        "devfocus.longBreakMinutes": {
          "type": "number",
          "default": 15,
          "minimum": 5,
          "maximum": 60,
          "description": "Default long break duration (minutes) for Custom mode"
        },
        "devfocus.dailyGoal": {
          "type": "number",
          "default": 8,
          "minimum": 0,
          "maximum": 24,
          "description": "Daily session goal shown in the panel and status bar (0 to disable)"
        },
        "devfocus.windDownTime": {
          "type": "string",
          "default": "18:00",
          "pattern": "^$|^([01]?[0-9]|2[0-3]):[0-5][0-9]$",
          "description": "Time of day (24h HH:MM) after which DevFocus nudges you to wrap up. Leave empty to disable."
        },
        "devfocus.microBreakMinutes": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 15,
          "description": "Auto-resume cap (minutes) for a micro-break — the open-ended rest ends itself at this limit so a forgotten break can't eat your session"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package",
    "publish": "vsce publish",
    "install:cursor": "vsce package && \"/Applications/Cursor.app/Contents/Resources/app/bin/cursor\" --install-extension \"devfocus-$(node -p \"require('./package.json').version\").vsix\" --force"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.85.0",
    "@vscode/codicons": "^0.0.36",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
